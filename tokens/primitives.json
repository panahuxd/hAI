    "yellow": {
      "50":  { "$type": "color", "$value": "#FEFCE8" },
      "700": { "$type": "color", "$value": "#A16207" }
    },
    "blue":   {
      "50":  { "$type": "color", "$value": "#EFF6FF" },
      "700": { "$type": "color", "$value": "#1D4ED8" }
    }
